{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Agent Guard",
  "version": "0.1.0",
  "identifier": "com.aigentguard.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AI Agent Guard",
        "width": 980,
        "height": 680,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "visible": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "© 2024 AI Agent Guard Contributors",
    "category": "DeveloperTool",
    "shortDescription": "Security monitor for Claude Code hooks",
    "longDescription": "AI Agent Guard monitors and controls Claude Code tool executions, blocking dangerous commands and alerting you to suspicious activity."
  }
}
